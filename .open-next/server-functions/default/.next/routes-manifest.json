{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/dashboard/countries/[code]",
      "regex": "^/dashboard/countries/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcode": "nxtPcode"
      },
      "namedRegex": "^/dashboard/countries/(?<nxtPcode>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/content",
      "regex": "^/admin/content(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/content(?:/)?$"
    },
    {
      "page": "/admin/sections",
      "regex": "^/admin/sections(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/sections(?:/)?$"
    },
    {
      "page": "/admin/theme",
      "regex": "^/admin/theme(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/theme(?:/)?$"
    },
    {
      "page": "/auth/signin",
      "regex": "^/auth/signin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/signin(?:/)?$"
    },
    {
      "page": "/auth/signup",
      "regex": "^/auth/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/signup(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/analysis",
      "regex": "^/dashboard/analysis(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/analysis(?:/)?$"
    },
    {
      "page": "/dashboard/comparison",
      "regex": "^/dashboard/comparison(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/comparison(?:/)?$"
    },
    {
      "page": "/dashboard/countries",
      "regex": "^/dashboard/countries(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/countries(?:/)?$"
    },
    {
      "page": "/dashboard/policy-briefs",
      "regex": "^/dashboard/policy\\-briefs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/policy\\-briefs(?:/)?$"
    },
    {
      "page": "/dashboard/trends",
      "regex": "^/dashboard/trends(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/trends(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}